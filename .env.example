# Copy these into Vercel → Settings → Environment Variables
# Never commit a real .env file to GitHub.

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJh...                 # safe to expose — protected by RLS
SUPABASE_SERVICE_ROLE_KEY=eyJh...         # SECRET — server only, never expose

# ── OpenRouter (all models — ChatGPT, Claude, Gemini, Grok, DeepSeek, 100+) ──
OPENROUTER_API_KEY=sk-or-...              # SECRET — server only

# ── Razorpay (India + international cards) ─────────────────
RAZORPAY_KEY_ID=rzp_live_...              # safe to expose
RAZORPAY_KEY_SECRET=...                   # SECRET — server only

# ── App ───────────────────────────────────────────────────
APP_URL=https://aiwebbb.pro
